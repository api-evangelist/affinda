{
  "opencollection": "1.0.0",
  "info": {
    "name": "Affinda Organizations API",
    "version": "3.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Organizations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get list of all organizations",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{region}.affinda.com/v3/organizations"
          },
          "docs": "Returns all the organizations"
        },
        {
          "info": {
            "name": "Get detail of an organization",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{region}.affinda.com/v3/organizations/:identifier",
            "params": [
              {
                "name": "identifier",
                "value": "",
                "type": "path",
                "description": "Organization identifier."
              }
            ]
          },
          "docs": "Get detail of an organization."
        }
      ]
    }
  ],
  "bundled": true
}