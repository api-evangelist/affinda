{
  "opencollection": "1.0.0",
  "info": {
    "name": "Affinda Tags API",
    "version": "3.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Tags",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get list of all tags",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{region}.affinda.com/v3/tags",
            "params": [
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "The numbers of results to return."
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "The number of documents to skip before starting to collect the result set."
              },
              {
                "name": "workspace",
                "value": "",
                "type": "query",
                "description": "Filter by workspace."
              },
              {
                "name": "name",
                "value": "",
                "type": "query",
                "description": "Filter by name."
              }
            ]
          },
          "docs": "Returns your tags."
        },
        {
          "info": {
            "name": "Create a tag",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{region}.affinda.com/v3/tags",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a tag"
        },
        {
          "info": {
            "name": "Get specific tag",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{region}.affinda.com/v3/tags/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "Tag's ID"
              }
            ]
          },
          "docs": "Return a specific tag."
        },
        {
          "info": {
            "name": "Update a tag",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://{region}.affinda.com/v3/tags/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "Tag's ID"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update data of an tag."
        },
        {
          "info": {
            "name": "Delete an tag",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://{region}.affinda.com/v3/tags/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path",
                "description": "Tag's ID"
              }
            ]
          },
          "docs": "Deletes the specified tag from the database."
        },
        {
          "info": {
            "name": "Add a tag to documents",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{region}.affinda.com/v3/documents/batch_add_tag",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Add a tag to documents.\nTags are used to group documents together.\nTags can be used to filter documents.\n"
        },
        {
          "info": {
            "name": "Remove a tag from documents",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{region}.affinda.com/v3/documents/batch_remove_tag",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Remove a tag from documents."
        }
      ]
    }
  ],
  "bundled": true
}