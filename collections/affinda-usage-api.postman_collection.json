      "item": [
        {
          "id": "16f1d16b-1eec-4253-a266-6604e93cfce1",
          "name": "Get usage",
          "request": {
            "name": "Get usage",
            "description": {
              "content": "Returns daily credits consumption for an organization over a date range. Optionally scope the report to a single workspace or document type.\n`workspace` and `document_type` cannot be combined: usage data is aggregated independently along each axis, so a per-(workspace × document type) slice is not available.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v3",
                "usage"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "organization",
                  "value": "<string>",
                  "description": "(Required) Organization to report usage for. The caller must be an admin or owner."
                },
                {
                  "disabled": false,
                  "key": "workspace",
                  "value": "<string>",
                  "description": "Optionally scope the report to a single workspace within the organization."
                },
                {
                  "disabled": false,
                  "key": "document_type",
                  "value": "<string>",
                  "description": "Optionally scope the report to a single document type within the organization."
                },
                {
                  "disabled": false,
                  "key": "start",
                  "value": "<date>",
                  "description": "Inclusive start date of the report (YYYY-MM-DD). Defaults to 365 days before `end`."
                },
                {
                  "disabled": false,
                  "key": "end",
                  "value": "<date>",
                  "description": "Inclusive end date of the report (YYYY-MM-DD). Defaults to today."
                }
              ],
              "variable": [
                {
                  "description": "The instance region. Use 'api' for AUS/Global, 'api.us1' for US, or 'api.eu1' for EU. You can find your region in the Affinda web app URL. (This can only be one of api,api.eu1,api.us1)",
                  "type": "any",
                  "value": "{{region}}",
                  "key": "region"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
